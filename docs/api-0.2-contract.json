{
  "schemaVersion": 1,
  "product": "RefactorKit",
  "implementationRelease": "0.4.0",
  "apiVersion": "0.2",
  "status": "beta-contract",
  "cli": {
    "commands": [
      "version", "scan", "index", "symbols", "diagnostics", "references",
      "definition", "rename", "rename-member", "extract-method",
      "change-signature", "move-class", "organize-imports", "format-file",
      "safe-delete", "patch rollback", "java import-class", "recipe run",
      "outline", "search", "local-rename", "test-golden"
    ],
    "booleanOptions": [
      "apply", "force", "stdin", "whole-word", "case-insensitive"
    ]
  },
  "daemon": {
    "transport": "json-rpc-2.0-ndjson-stdio",
    "methods": [
      {"name": "server.version", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "server.capabilities", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "project.open", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "project.summary", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.search", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.definition", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.references", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "diagnostics", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "refactor.preview", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "refactor.apply", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": true},
      {"name": "patch.rollback", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": true},
      {"name": "java.importExternalClass", "stability": "experimental", "requiresProject": true, "writesWorkspace": false}
    ],
    "refactorOperations": [
      "renameClass", "renameMember", "extractMethod",
      "changeSignature.renameParameter", "changeSignature.addParameter",
      "changeSignature.reorderParameters", "changeSignature.removeParameter",
      "moveClass", "organizeImports", "formatFile", "safeDelete"
    ]
  },
  "limits": {
    "maxRequestBytes": 1048576,
    "maxLspFrameBytes": 1048576,
    "maxPendingPlans": 128,
    "maxSymbolResults": 200,
    "maxReferenceResults": 1000
  },
  "safety": {
    "previewBeforeApply": true,
    "snapshotValidation": true,
    "diagnosticsGate": true,
    "transactionRollback": true,
    "workspaceScopedWrites": true,
    "lexicalFallbackApply": false
  }
}
