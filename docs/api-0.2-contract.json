{
  "schemaVersion": 1,
  "product": "RefactorKit",
  "implementationRelease": "0.7.0-SNAPSHOT",
  "apiVersion": "0.2",
  "status": "beta-contract",
  "cli": {
    "commands": [
      "version", "capabilities", "scan", "index", "intelligence search", "symbols", "diagnostics", "references",
      "definition", "rename", "rename-member", "extract-method",
      "change-signature", "move-class", "organize-imports", "format-file",
      "safe-delete", "patch recover", "patch rollback", "java import-class", "java move-source-root", "recipe run",
      "outline", "search", "local-rename", "typescript", "kotlin", "test-golden"
    ],
    "booleanOptions": [
      "apply", "force", "stdin", "whole-word", "case-insensitive", "resolve-dependencies", "verbose",
      "allow-workspace-local-toolchain", "allow-external-consumers", "allow-dynamic-references", "json"
    ]
  },
  "daemon": {
    "transport": "json-rpc-2.0-ndjson-stdio",
    "methods": [
      {"name": "server.version", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "server.capabilities", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "project.open", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "project.summary", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false,
       "features": {"buildModelSummary": true, "sourceSets": true, "credentialRedaction": true,
                    "boundedBuildModelSummary": true, "typedBuildModelSchema": true,
                    "offlineMissingStatus": true, "executionRefusedStatus": true}},
      {"name": "index.status", "stability": "additive-api-0.2", "requiresProject": true, "writesWorkspace": false,
       "features": {"wholeWorkspaceSourceInventory": true, "providerContributions": true,
                    "snapshotBound": true, "bounded": true}},
      {"name": "intelligence.query", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"workspaceSymbols": true, "documentSymbols": true,
                    "immutableEditorOverlayDocumentSymbols": true, "semanticLease": true,
                    "completion": false, "hover": true, "immutableEditorOverlayHover": true,
                    "signatureHelp": false, "definitionAtPosition": false,
                    "referencesAtPosition": false, "snapshotBound": true, "typedRefusal": true,
                    "bounded": true}},
      {"name": "typescript.semantic.start", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"explicitToolchain": true, "hashBoundProvenance": true, "noPackageScripts": true,
                    "workspaceIndexContribution": true, "aggregateSymbolDeadline": true,
                    "explicitSymbolTruncation": true}},
      {"name": "typescript.semantic.restart", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"workspaceIndexRefresh": true, "semanticLeaseRotation": true}},
      {"name": "typescript.semantic.stop", "stability": "experimental", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.search", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.definition", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "symbol.references", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "diagnostics", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "diagnostics.v2", "stability": "additive-api-0.2", "requiresProject": true, "writesWorkspace": false,
       "features": {"requestCorrelation": true, "semanticLease": true, "savedDiskAuthority": true,
                    "immutableEditorOverlay": true, "exactUtf16Ranges": true, "structuredReadiness": true,
                    "compilerAttestation": true, "boundedResponse": true}},
      {"name": "kotlin.semantic.start", "stability": "experimental", "requiresProject": true, "writesWorkspace": false},
      {"name": "kotlin.semantic.stop", "stability": "experimental", "requiresProject": true, "writesWorkspace": false},
      {"name": "kotlin.diagnostics", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"semanticLease": true, "snapshotAttestation": true, "compilerAttestation": true,
                    "boundedProcess": true, "lineOnlyPrecision": true}},
      {"name": "kotlin.symbols", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"semanticLease": true, "snapshotAttestation": true, "compilerBacked": true,
                    "durableJvmTypeIds": true, "exactUtf16Ranges": true, "documentFilter": true,
                    "boundedResponse": true}},
      {"name": "kotlin.definition", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"semanticLease": true, "snapshotAttestation": true, "compilerBacked": true,
                    "opaqueSymbolId": true, "exactUtf16Ranges": true}},
      {"name": "refactor.preview", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": false},
      {"name": "refactor.apply", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": true},
      {"name": "refactor.discard", "stability": "beta-contract", "requiresProject": false, "writesWorkspace": false},
      {"name": "patch.recover", "stability": "experimental", "requiresProject": false, "writesWorkspace": true},
      {"name": "patch.rollback", "stability": "beta-contract", "requiresProject": true, "writesWorkspace": true},
      {"name": "java.importExternalClass", "stability": "experimental", "requiresProject": true, "writesWorkspace": false,
       "features": {"targetDirectory": true, "preview": true, "renderedDiff": true, "structuredDiff": true,
                    "previewDiagnostics": true, "apply": true, "discard": true, "rollback": true}}
    ],
    "refactorOperations": [
      "renameClass", "renameMember", "extractMethod",
      "changeSignature.renameParameter", "changeSignature.addParameter",
      "changeSignature.reorderParameters", "changeSignature.removeParameter",
      "moveClass", "moveSourceRoot", "organizeImports", "formatFile", "safeDelete", "renameSymbol"
    ]
  },
  "languageKernel": {
    "schemaVersion": 1,
    "surfaces": ["cli", "daemon", "lsp-experimental", "mcp-extension"],
    "packagedAdapters": ["java", "javascript", "kotlin", "typescript"],
    "capabilityLayerFields": ["backend", "runtime", "extensions", "diagnosticSnapshotModes", "diagnosticRangeCapability"]
  },
  "limits": {
    "maxRequestBytes": 1048576,
    "maxLspFrameBytes": 1048576,
    "maxExternalLspFrameBytes": 8388608,
    "maxPendingPlans": 128,
    "maxSymbolResults": 200,
    "maxReferenceResults": 1000,
    "maxPreviewDiffBytes": 524288,
    "maxPreviewDiffFiles": 128,
    "maxPreviewHunksPerFile": 64,
    "maxPreviewLinesPerHunk": 2000,
    "maxPreviewDiagnostics": 500,
    "maxPreviewDiagnosticBytes": 262144,
    "maxDiagnosticMessageChars": 4096,
    "maxDiagnosticsResponseBytes": 2097152,
    "maxDiagnosticsRequestIdChars": 128,
    "maxDiagnosticsOverlayDocuments": 128,
    "maxDiagnosticsOverlayBytes": 786432,
    "maxKotlinDiagnosticsSourceFiles": 96,
    "maxKotlinDiagnosticsClasspathEntries": 128,
    "maxKotlinDiagnosticsOutputBytes": 8388608,
    "maxKotlinCompilerSymbols": 500,
    "maxDaemonStderrBytes": 65536,
    "maxBuildModels": 16,
    "maxBuildModules": 1024,
    "maxBuildSourceSetsPerModule": 64,
    "maxBuildRootsPerSourceSet": 256,
    "maxBuildModuleDependenciesPerSourceSet": 1024,
    "maxBuildModelDiagnostics": 500,
    "maxSemanticProcesses": 8,
    "maxSemanticProcessArguments": 128,
    "maxSemanticProcessStdoutBytes": 67108864,
    "maxSemanticProcessStderrBytes": 65536,
    "maxSemanticOverlayFiles": 100000,
    "maxSemanticOverlayBytes": 536870912,
    "maxExternalFileEdits": 1000,
    "maxExternalTextEdits": 10000,
    "maxExternalReplacementBytes": 16777216,
    "maxMavenDependencies": 4096,
    "maxMavenDependencyDepth": 128,
    "maxMavenParentDepth": 32,
    "maxMavenNetworkArtifactBytes": 268435456
  },
  "safety": {
    "previewBeforeApply": true,
    "snapshotValidation": true,
    "diagnosticsGate": true,
    "transactionRollback": true,
    "workspaceScopedWrites": true,
    "lexicalFallbackApply": false
  }
}
