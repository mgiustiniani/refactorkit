{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://refactorkit.org/schemas/api-0.2-intelligence-query.json",
  "title": "RefactorKit API 0.2 intelligence.query response",
  "oneOf": [
    {"$ref": "#/$defs/ready"},
    {"$ref": "#/$defs/completion"},
    {"$ref": "#/$defs/definition"},
    {"$ref": "#/$defs/references"},
    {"$ref": "#/$defs/javaHover"},
    {"$ref": "#/$defs/hover"},
    {"$ref": "#/$defs/signatureHelp"},
    {"$ref": "#/$defs/refused"}
  ],
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {
        "line": {"type": "integer", "minimum": 0},
        "character": {"type": "integer", "minimum": 0}
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "range"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": {"$ref": "#/$defs/position"},
            "end": {"$ref": "#/$defs/position"}
          }
        }
      }
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "symbolKind", "languageId", "providerId", "backend", "evidence", "completeness", "location"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "symbolKind": {"type": "string"},
        "languageId": {"type": "string"},
        "providerId": {"type": "string"},
        "backend": {"type": "string"},
        "evidence": {"enum": ["compiler", "language-server", "native-ast", "structural-parse", "lexical"]},
        "completeness": {"enum": ["declarations", "semantic"]},
        "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "location": {"$ref": "#/$defs/location"}
      }
    },
    "base": {
      "type": "object",
      "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration"],
      "properties": {
        "schemaVersion": {"const": 1},
        "requestId": {"type": "string", "minLength": 1, "maxLength": 128},
        "status": {"enum": ["ready", "refused"]},
        "kind": {"type": "string"},
        "snapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "indexGeneration": {"type": "integer", "minimum": 1}
      }
    },
    "ready": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration", "coverage", "missingProviderLanguages", "total", "returned", "truncated", "items"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "providerSnapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "sourceAuthority": {"type": "object"},
            "status": {"const": "ready"},
            "kind": {"enum": ["workspaceSymbols", "documentSymbols"]},
            "coverage": {"enum": ["source-inventory", "partial", "declarations", "semantic"]},
            "missingProviderLanguages": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
            "total": {"type": "integer", "minimum": 0},
            "returned": {"type": "integer", "minimum": 0, "maximum": 200},
            "truncated": {"type": "boolean"},
            "items": {"type": "array", "maxItems": 200, "items": {"$ref": "#/$defs/symbol"}}
          }
        }
      ]
    },
    "definition": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration", "providerId", "backend", "evidence", "completeness", "provenanceHash", "locations", "sourceAuthority", "cache"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "definition"},
            "providerId": {"const": "java-jdt-bindings-v1"},
            "backend": {"const": "eclipse-jdt-3.44-bindings-v1"},
            "evidence": {"const": "compiler"}, "completeness": {"const": "semantic"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "locations": {"type": "array", "maxItems": 1, "items": {"$ref": "#/$defs/location"}},
            "sourceAuthority": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "contentSha256"], "properties": {
              "kind": {"const": "saved-snapshot"}, "path": {"type": "string"},
              "contentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }},
            "cache": {"type": "object", "additionalProperties": false, "required": ["entries", "hits", "misses"], "properties": {
              "entries": {"type": "integer", "minimum": 1, "maximum": 2},
              "hits": {"type": "integer", "minimum": 0}, "misses": {"type": "integer", "minimum": 0}
            }}
          }
        }
      ]
    },
    "references": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration", "providerId", "backend", "evidence", "completeness", "provenanceHash", "total", "returned", "truncated", "complete", "warningCount", "references", "sourceAuthority", "cache"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "references"},
            "providerId": {"const": "java-jdt-bindings-v1"},
            "backend": {"const": "eclipse-jdt-3.44-bindings-v1"},
            "evidence": {"const": "compiler"}, "completeness": {"const": "semantic"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "total": {"type": "integer", "minimum": 0}, "returned": {"type": "integer", "minimum": 0, "maximum": 1000},
            "truncated": {"type": "boolean"}, "complete": {"type": "boolean"},
            "warningCount": {"type": "integer", "minimum": 0},
            "references": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/location"}},
            "sourceAuthority": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "contentSha256"], "properties": {
              "kind": {"const": "saved-snapshot"}, "path": {"type": "string"},
              "contentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }},
            "cache": {"type": "object", "additionalProperties": false, "required": ["entries", "hits", "misses"], "properties": {
              "entries": {"type": "integer", "minimum": 1, "maximum": 2},
              "hits": {"type": "integer", "minimum": 0}, "misses": {"type": "integer", "minimum": 0}
            }}
          }
        }
      ]
    },
    "completion": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "providerSnapshotHash", "indexGeneration", "providerId", "backend", "evidence", "provenanceHash", "incomplete", "items", "sourceAuthority"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "completion"},
            "providerSnapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "providerId": {"type": "string"}, "backend": {"type": "string"},
            "evidence": {"const": "language-server"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "incomplete": {"type": "boolean"},
            "items": {"type": "array", "maxItems": 200, "items": {"type": "object", "additionalProperties": false, "required": ["label", "symbolKind", "insertTextFormat", "commitCharacters", "additionalTextEdits"], "properties": {
              "label": {"type": "string", "minLength": 1, "maxLength": 512}, "symbolKind": {"type": "string"},
              "detail": {"type": "string", "maxLength": 4096}, "documentation": {"type": "string", "maxLength": 16384},
              "sortText": {"type": "string", "maxLength": 65536}, "filterText": {"type": "string", "maxLength": 65536},
              "insertText": {"type": "string", "maxLength": 65536},
              "insertTextFormat": {"enum": ["plain-text", "snippet"]},
              "commitCharacters": {"type": "array", "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 8}},
              "replacementRange": {"$ref": "#/$defs/location/properties/range"},
              "additionalTextEdits": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["range", "newText"], "properties": {"range": {"$ref": "#/$defs/location/properties/range"}, "newText": {"type": "string", "maxLength": 65536}}}}
            }}},
            "sourceAuthority": {"type": "object"}
          }
        }
      ]
    },
    "javaHover": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration", "providerId", "backend", "evidence", "completeness", "provenanceHash", "range", "contents", "complete", "warningCount", "sourceAuthority", "cache"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "hover"},
            "providerId": {"const": "java-jdt-bindings-v1"}, "backend": {"const": "eclipse-jdt-3.44-bindings-v1"},
            "evidence": {"const": "compiler"}, "completeness": {"const": "semantic"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "range": {"oneOf": [{"$ref": "#/$defs/location/properties/range"}, {"type": "null"}]},
            "contents": {"type": "array", "maxItems": 3, "items": {"type": "object", "additionalProperties": false, "required": ["format", "value"], "properties": {
              "format": {"enum": ["plain-text", "markdown"]}, "value": {"type": "string", "maxLength": 16384}
            }}},
            "complete": {"type": "boolean"}, "warningCount": {"type": "integer", "minimum": 0},
            "sourceAuthority": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "contentSha256"], "properties": {
              "kind": {"const": "saved-snapshot"}, "path": {"type": "string"},
              "contentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }},
            "cache": {"type": "object", "additionalProperties": false, "required": ["entries", "hits", "misses"], "properties": {
              "entries": {"type": "integer", "minimum": 1, "maximum": 2},
              "hits": {"type": "integer", "minimum": 0}, "misses": {"type": "integer", "minimum": 0}
            }}
          }
        }
      ]
    },
    "hover": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "providerSnapshotHash", "indexGeneration", "providerId", "backend", "evidence", "provenanceHash", "range", "contents", "sourceAuthority"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "hover"},
            "providerSnapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "providerId": {"type": "string"}, "backend": {"type": "string"},
            "evidence": {"const": "language-server"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "range": {"oneOf": [{"$ref": "#/$defs/location/properties/range"}, {"type": "null"}]},
            "contents": {"type": "array", "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["format", "value"], "properties": {"format": {"enum": ["plain-text", "markdown"]}, "value": {"type": "string", "maxLength": 16384}}}},
            "sourceAuthority": {"type": "object"}
          }
        }
      ]
    },
    "signatureHelp": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "providerSnapshotHash", "indexGeneration", "providerId", "backend", "evidence", "provenanceHash", "activeSignature", "activeParameter", "signatures", "sourceAuthority"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "ready"}, "kind": {"const": "signatureHelp"},
            "providerSnapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "providerId": {"type": "string"}, "backend": {"type": "string"},
            "evidence": {"const": "language-server"},
            "provenanceHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "activeSignature": {"type": ["integer", "null"], "minimum": 0},
            "activeParameter": {"type": ["integer", "null"], "minimum": 0},
            "signatures": {"type": "array", "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["label", "parameters"], "properties": {
              "label": {"type": "string", "minLength": 1, "maxLength": 8192},
              "documentation": {"type": "string", "maxLength": 16384},
              "parameters": {"type": "array", "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["labelStart", "labelEnd"], "properties": {
                "labelStart": {"type": "integer", "minimum": 0}, "labelEnd": {"type": "integer", "minimum": 0},
                "documentation": {"type": "string", "maxLength": 16384}
              }}}
            }}},
            "sourceAuthority": {"type": "object"}
          }
        }
      ]
    },
    "refused": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "requestId", "status", "kind", "snapshotHash", "indexGeneration", "error"],
          "properties": {
            "schemaVersion": {}, "requestId": {}, "kind": {}, "snapshotHash": {}, "indexGeneration": {},
            "status": {"const": "refused"},
            "error": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": {"type": "string"},
                "message": {"type": "string"}
              }
            }
          }
        }
      ]
    }
  }
}
