{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://refactorkit.org/schema/api-0.2-workspace-refresh.json",
  "title": "RefactorKit workspace.refresh result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "snapshotHash", "generation", "invalidatedProviders", "stoppedSemanticLanguages"],
  "properties": {
    "status": {"enum": ["ready", "unchanged", "refused"]},
    "snapshotHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "generation": {"type": "integer", "minimum": 1},
    "message": {"type": "string"},
    "invalidatedProviders": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{0,127}$"}
    },
    "stoppedSemanticLanguages": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}
    },
    "changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "modified", "deleted", "unchanged", "paths", "pathsTruncated"],
      "properties": {
        "added": {"type": "integer", "minimum": 0},
        "modified": {"type": "integer", "minimum": 0},
        "deleted": {"type": "integer", "minimum": 0},
        "unchanged": {"type": "integer", "minimum": 0},
        "paths": {"type": "array", "maxItems": 200, "items": {"type": "string"}},
        "pathsTruncated": {"type": "boolean"}
      }
    }
  }
}
